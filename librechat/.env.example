# =============================================================
# Anima 灵枢 · LibreChat 环境变量配置模板
# 部署节点：VPS C (172.16.1.3)
#
# 使用方法：
#   cp .env.example .env
#   vim .env  # 替换所有 <尖括号> 内的占位符
#   chmod 600 .env
#
# ★ 默认免费模型：glm-4-flash（智谱，官方免费，0 成本）★
#   只需填写 ZHIPU_API_KEY 即可使用默认免费模型。
# =============================================================

# ─── 服务器监听（只监听内网，不暴露公网）────────────────────
HOST=172.16.1.3
PORT=3080

# ─── 域名（用于生成链接、CORS 等）───────────────────────────
DOMAIN_CLIENT=https://<你的域名>
DOMAIN_SERVER=https://<你的域名>

# ─── JWT 密钥（必须更换为随机值，至少 64 字符）──────────────
# 生成方法（生成 32 字节 = 64 个十六进制字符）：
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=<生成一个 64 字符随机十六进制字符串>
JWT_REFRESH_SECRET=<再生成一个不同的 64 字符随机十六进制字符串>

# ─── 数据库（Azure PostgreSQL）──────────────────────────────
POSTGRES_URI=postgresql://animaapp:<animaapp密码>@anima-db.postgres.database.azure.com:5432/librechat?sslmode=require

# ─── Redis 缓存（CXI4）──────────────────────────────────────
REDIS_URI=redis://:<Redis密码>@172.16.1.5:6379

# ─── AI 推理后端 ─────────────────────────────────────────────
# 本地 Ollama 接口保留定义，当前不启用（api_models.is_active=false）
# 如需重新启用，将下行注释取消，并在数据库中执行：
#   UPDATE api_models SET is_active=true WHERE provider='ollama';
# OLLAMA_BASE_URL=http://172.16.1.5:11434

# ══════════════════════════════════════════════════════════════
# 云端 API 密钥（按需配置，只填写你实际使用的）
# ══════════════════════════════════════════════════════════════
# 管理员可在 POST /admin/models 中添加对应模型定价

# ─────────── 全球 Top 10 提供商 ───────────────────────────────

# ── 1. Anthropic / Claude ─────────────────────────────────────
# 申请：https://console.anthropic.com/
ANTHROPIC_API_KEY=<你的 Claude API Key，如不使用留空>

# ── 2. OpenAI ─────────────────────────────────────────────────
# 申请：https://platform.openai.com/
OPENAI_API_KEY=<你的 OpenAI API Key，如不使用留空>

# ── 3. Google Gemini（谷歌）──────────────────────────────────
# 申请：https://aistudio.google.com/apikey
# LibreChat 的 Google 端点使用 GOOGLE_KEY 变量名
GOOGLE_KEY=<你的 Google AI Studio API Key，如不使用留空>

# ── 4. xAI / Grok ─────────────────────────────────────────────
# 申请：https://console.x.ai/
XAI_API_KEY=<你的 xAI API Key，如不使用留空>

# ── 5. Mistral AI ─────────────────────────────────────────────
# 申请：https://console.mistral.ai/
MISTRAL_API_KEY=<你的 Mistral API Key，如不使用留空>

# ── 6. Cohere ─────────────────────────────────────────────────
# 申请：https://dashboard.cohere.com/
COHERE_API_KEY=<你的 Cohere API Key，如不使用留空>

# ── 7. Groq（超高速推理，有免费层）────────────────────────────
# 申请：https://console.groq.com/
GROQ_API_KEY=<你的 Groq API Key，如不使用留空>

# ── 8. Perplexity（联网搜索增强）──────────────────────────────
# 申请：https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=<你的 Perplexity API Key，如不使用留空>

# ─────────── 中国 Top 5 提供商 ────────────────────────────────

# ── 中1. DeepSeek（深度求索）─────────────────────────────────
# 申请：https://platform.deepseek.com/
# 价格极低：约 ¥0.001/1K 输入，¥0.002/1K 输出
DEEPSEEK_API_KEY=<你的 DeepSeek API Key，如不使用留空>

# ── 中2. Qwen 通义千问（阿里云灵积）─────────────────────────
# 申请：https://dashscope.aliyuncs.com/
QWEN_API_KEY=<你的 DashScope API Key，如不使用留空>

# ── 中3. Moonshot / Kimi（月之暗面）─────────────────────────
# 申请：https://platform.moonshot.cn/
MOONSHOT_API_KEY=<你的 Moonshot API Key，如不使用留空>

# ── 中4. Zhipu AI / GLM（智谱清言）──────────────────────────
# 申请：https://open.bigmodel.cn/
# ★ glm-4-flash 完全免费，推荐必填 ★
ZHIPU_API_KEY=<你的智谱 API Key>

# ── 中5-A. ByteDance / 豆包（字节跳动火山方舟）─────────────
# 申请：https://console.volcengine.com/ark
DOUBAO_API_KEY=<你的火山方舟 API Key，如不使用留空>

# ── 中5-B. Baidu / ERNIE 文心一言（百度千帆）────────────────
# 申请：https://console.bce.baidu.com/qianfan/
BAIDU_API_KEY=<你的百度千帆 API Key，如不使用留空>

# ─── 用户注册设置 ─────────────────────────────────────────────
# true = 允许公开注册；false = 仅管理员邀请
ALLOW_REGISTRATION=true
# 注册邮箱白名单（空 = 不限制；逗号分隔）
REGISTRATION_SOCIAL_ALLOWED=false

# ─── 邮件服务（密码重置用）───────────────────────────────────
EMAIL_SERVICE=<smtp 服务，如 gmail 或 smtp.qq.com>
EMAIL_USERNAME=<邮箱账号>
EMAIL_PASSWORD=<邮箱 SMTP 密码/授权码>
EMAIL_FROM=<发件人邮箱>

# ─── 加密 & 安全 ─────────────────────────────────────────────
# 用于加密存储的 API Key
CREDS_KEY=<32 字节随机 HEX>
CREDS_IV=<16 字节随机 HEX>

# ─── 文件上传 ─────────────────────────────────────────────────
# 单文件大小限制（字节）
FILE_SIZE_LIMIT=52428800   # 50 MB

# ─── 会话配置 ─────────────────────────────────────────────────
SESSION_EXPIRY=86400000    # 24 小时（毫秒）
REFRESH_TOKEN_EXPIRY=604800000  # 7 天（毫秒）

# ─── 时区 ─────────────────────────────────────────────────────
TZ=Asia/Shanghai

# ─── 日志级别 ─────────────────────────────────────────────────
DEBUG_LOGGING=false
LOG_LEVEL=info
