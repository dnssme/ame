# =============================================================
# Anima 灵枢 · Git 忽略规则
# PCI-DSS 3.4: 禁止将密钥/凭据提交到版本控制
# =============================================================

# ─── 环境变量文件（含密钥/凭据）──────────────────────────────
.env
.env.local
.env.production
# 保留 .env.example 模板
!.env.example

# ─── 依赖目录 ─────────────────────────────────────────────────
node_modules/

# ─── 根目录误生成的 package 文件（各子模块有自己的 package.json）──
/package.json
/package-lock.json

# ─── 日志文件 ─────────────────────────────────────────────────
*.log
logs/

# ─── 运行时数据 ───────────────────────────────────────────────
data/
uploads/
tmp/

# ─── OS 生成文件 ──────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# ─── IDE 配置 ─────────────────────────────────────────────────
.vscode/
.idea/
*.iml
