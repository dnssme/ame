# =============================================================
# Anima 灵枢 · Webhook 计费服务环境变量
# 部署节点：CXI4 (172.16.1.5)
#
# 使用方法：
#   cp .env.example .env
#   vim .env  # 替换所有 <占位符> 为真实值
#   chmod 600 .env
# =============================================================

# ─── PostgreSQL 数据库（Azure 托管）─────────────────────────
PG_HOST=anima-db.postgres.database.azure.com
PG_PORT=5432
PG_USER=animaapp
PG_PASSWORD=<Azure PostgreSQL 密码>
PG_DATABASE=librechat

# ─── Redis（CXI4 本机，用于免费用户每日限额计数）────────────
# ⚠️ 必须包含密码，否则连接会静默失败导致免费限额失效
REDIS_URL=redis://:<Redis密码>@172.16.1.5:6379

# ─── 免费用户每日调用次数限制 ─────────────────────────────────
# 免费模型（is_free=true）每用户每日最多调用次数
# 付费模型不受此限制
FREE_DAILY_LIMIT=20

# ─── 管理员令牌（用于 /admin/* 接口鉴权）────────────────────
ADMIN_TOKEN=<随机生成的管理员令牌，至少 32 字符>

# ─── 内部服务鉴权令牌（用于 /billing/* 写入接口）─────────────
# OpenClaw 等内部服务调用 /billing/record、/billing/check 时携带此 Token
# ⚠️ 未配置则拒绝所有写入请求（fail-closed），务必设置并与 openclaw SERVICE_TOKEN 保持一致
SERVICE_TOKEN=<随机生成的服务间鉴权令牌，至少 32 字符>

# ─── 单次请求最大扣费（安全熔断，单位：分）─────────────────
# 超过此值会返回 HTTP 402，防止单次调用把余额耗尽
MAX_SINGLE_REQUEST_FEN=1000

# ─── USD → CNY 汇率（用于国际模型定价换算）─────────────────
# Anthropic/OpenAI/Google 等 USD 定价模型按此汇率换算为人民币分
# 不设置时代码默认使用 7.2；请定期更新为当前中间价
# 参考：https://www.boc.cn/sourcedb/whpj/
USD_TO_CNY_RATE=7.2

# ─── 服务配置 ────────────────────────────────────────────────
PORT=3002
# Docker 容器内必须绑定 0.0.0.0；裸机部署可改为内网 IP（如 172.16.1.5）
HOST=0.0.0.0
NODE_ENV=production
LOG_LEVEL=info
TZ=Asia/Shanghai

# ─── Nginx 反向代理 IP（用于 trust proxy，获取客户端真实 IP）─
# 若 Nginx 部署 IP 变更，需同步修改
TRUST_PROXY=172.16.1.1

# ─── Node.js 内存限制 ────────────────────────────────────────
# CXI4 上 Webhook 分配 256MB
NODE_OPTIONS=--max-old-space-size=256
