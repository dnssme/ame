# =============================================================
# Anima 灵枢 · 微信接入模块环境变量
# =============================================================

# ─── Wechaty 配置 ───────────────────────────────────────────
# Puppet 类型：wechaty-puppet-wechat（免费网页版）
#            wechaty-puppet-padlocal（iPad 协议，需付费 token）
#            wechaty-puppet-service（远程 puppet 服务）
WECHATY_PUPPET=wechaty-puppet-wechat
# 如使用 padlocal 或 service，填写 token
WECHATY_TOKEN=<你的 Wechaty Puppet Token，免费版留空>

# ─── AI 后端 ────────────────────────────────────────────────
AGENT_API_URL=http://172.16.1.2:3000
AGENT_DEFAULT_MODEL=glm-4-flash  # ★ 默认免费模型（智谱官方免费，0 成本）★

# ─── 计费（可选）────────────────────────────────────────────
BILLING_WEBHOOK_URL=http://172.16.1.5:3002

# ─── Redis（会话上下文）──────────────────────────────────────
REDIS_URL=redis://:<your_redis_password>@172.16.1.5:6379
SESSION_TTL=3600

# ─── 语音处理（可选）────────────────────────────────────────
VOICE_ENABLED=true
WHISPER_URL=http://172.16.1.5:8080/transcribe
TTS_URL=http://172.16.1.5:8082/api/tts

# ─── 群聊设置 ────────────────────────────────────────────────
# 群聊中只响应 @机器人 的消息
GROUP_AT_ONLY=true
# 机器人名称（群聊中 @ 用的名字）
BOT_NAME=Anima

# ─── 日志 ────────────────────────────────────────────────────
LOG_LEVEL=info
TZ=Asia/Shanghai
