# =============================================================
# Anima 灵枢 · Telegram 接入模块环境变量
# =============================================================

# ─── Telegram Bot 配置 ──────────────────────────────────────
# 通过 @BotFather 获取
TELEGRAM_BOT_TOKEN=<你的 Telegram Bot Token>

# ─── AI 后端 ────────────────────────────────────────────────
AGENT_API_URL=http://172.16.1.2:3000
AGENT_DEFAULT_MODEL=claude-haiku-4-5-20251001

# ─── 计费（可选）────────────────────────────────────────────
BILLING_ENABLED=true
BILLING_WEBHOOK_URL=http://172.16.1.5:3002

# ─── Redis（会话上下文）──────────────────────────────────────
REDIS_URL=redis://:${REDIS_PASSWORD}@172.16.1.5:6379
SESSION_TTL=3600

# ─── 语音处理（可选）────────────────────────────────────────
VOICE_ENABLED=true
WHISPER_URL=http://172.16.1.5:8080/transcribe
TTS_URL=http://172.16.1.1:8082/api/tts

# ─── 访问控制（可选）────────────────────────────────────────
# 允许使用 Bot 的 Telegram 用户 ID（逗号分隔，留空=所有人可用）
ALLOWED_USER_IDS=

# ─── 日志 ────────────────────────────────────────────────────
LOG_LEVEL=info
TZ=Asia/Shanghai
