# =============================================================
# Anima 灵枢 · OpenClaw Agent 环境变量配置模板
# 部署节点：VPS B (172.16.1.2)
#
# 使用方法：
#   cp .env.example .env
#   vim .env   # 替换所有 <尖括号> 内的占位符
#   chmod 600 .env
# =============================================================

# ─── AI 推理 API 密钥 ────────────────────────────────────────
# 只需填写你实际使用的服务，其余留空即可
# ── 已集成提供商 ──────────────────────────────────────────────
ANTHROPIC_API_KEY=<你的 Claude API Key>
OPENAI_API_KEY=<你的 OpenAI API Key，如不使用留空>
MISTRAL_API_KEY=<你的 Mistral API Key，如不使用留空>

# ── Google Gemini（谷歌）─────────────────────────────────────
# 申请：https://aistudio.google.com/apikey
GOOGLE_API_KEY=<你的 Google AI Studio API Key，如不使用留空>

# ── DeepSeek（深度求索）──────────────────────────────────────
# 申请：https://platform.deepseek.com/
DEEPSEEK_API_KEY=<你的 DeepSeek API Key，如不使用留空>

# ── Qwen 通义千问（阿里云灵积）──────────────────────────────
# 申请：https://dashscope.aliyuncs.com/
QWEN_API_KEY=<你的 DashScope API Key，如不使用留空>

# ── Moonshot / Kimi（月之暗面）──────────────────────────────
# 申请：https://platform.moonshot.cn/
MOONSHOT_API_KEY=<你的 Moonshot API Key，如不使用留空>

# ── Zhipu AI / GLM（智谱清言）───────────────────────────────
# 申请：https://open.bigmodel.cn/
ZHIPU_API_KEY=<你的智谱 API Key，如不使用留空>

# ── xAI / Grok ───────────────────────────────────────────────
# 申请：https://console.x.ai/
XAI_API_KEY=<你的 xAI API Key，如不使用留空>

# ── Groq（快速推理，有免费层）───────────────────────────────
# 申请：https://console.groq.com/
GROQ_API_KEY=<你的 Groq API Key，如不使用留空>

# ─── 数据库（OpenClaw 记忆库）────────────────────────────────
PG_PASSWORD=<animaapp 数据库密码>

# ─── Redis 缓存（CXI4 内网）─────────────────────────────────
REDIS_PASSWORD=<Redis 密码>

# ─── 工具集成 ────────────────────────────────────────────────
NEXTCLOUD_PASSWORD=<Nextcloud admin 密码>
HA_TOKEN=<Home Assistant 长期访问令牌>
