# =============================================================
# Anima 灵枢 · Nextcloud 环境变量配置模板
# 部署节点：CXI4 (172.16.1.5)
#
# 使用方法：
#   cp .env.example .env
#   vim .env   # 替换所有 <尖括号> 内的占位符
#   chmod 600 .env
# =============================================================

# ─── 数据库 ──────────────────────────────────────────────────
PG_PASSWORD=<animaapp 数据库密码>

# ─── Nextcloud 管理员账户 ────────────────────────────────────
NEXTCLOUD_USERNAME=admin
NEXTCLOUD_PASSWORD=<Nextcloud 管理员密码，建议随机生成 32 位>

# ─── 域名（用于可信域名白名单）────────────────────────────────
# 如有公网域名，填写完整域名，如 cloud.example.com
NEXTCLOUD_DOMAIN=<你的 Nextcloud 域名，如不使用公网访问可留空>
