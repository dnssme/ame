# =============================================================
# Anima 灵枢 · 日历管理模块环境变量
# =============================================================

# ─── Nextcloud CalDAV 配置 ──────────────────────────────────
NEXTCLOUD_URL=http://172.16.1.5:8090
NEXTCLOUD_USERNAME=admin
NEXTCLOUD_PASSWORD=<Nextcloud admin 密码>
NEXTCLOUD_CALENDAR_NAME=anima
NEXTCLOUD_DOMAIN=<你的域名>

# ─── AI 后端 ────────────────────────────────────────────────
AGENT_API_URL=http://172.16.1.2:3000
AGENT_DEFAULT_MODEL=glm-4-flash  # ★ 默认免费模型（智谱官方免费，0 成本）★

# ─── 提醒通知（可选）────────────────────────────────────────
REMINDER_ENABLED=true
# 通知渠道：telegram / wechat
REMINDER_CHANNEL=telegram
TELEGRAM_BOT_TOKEN=<Bot Token>
TELEGRAM_CHAT_ID=<Chat ID>

# ─── 日志 ────────────────────────────────────────────────────
LOG_LEVEL=info
TZ=Asia/Shanghai
