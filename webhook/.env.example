# =============================================================
# Anima 灵枢 · Webhook 计费服务环境变量
# 部署节点：CXI4 (172.16.1.5)
#
# 使用方法：
#   cp .env.example .env
#   vim .env  # 替换所有 <占位符> 为真实值
#   chmod 600 .env
# =============================================================

# ─── PostgreSQL 数据库（Azure 托管）─────────────────────────
DB_HOST=anima-db.postgres.database.azure.com
DB_PORT=5432
DB_USER=animaapp
DB_PASSWORD=<Azure PostgreSQL 密码>
DB_NAME=librechat
DB_SSL=require

# ─── Redis（CXI4 本机，用于免费用户每日限额计数）────────────
REDIS_URL=redis://:${REDIS_PASSWORD}@172.16.1.5:6379

# ─── 免费用户每日调用次数限制 ─────────────────────────────────
# 免费模型（is_free=true）每用户每日最多调用次数
# 付费模型不受此限制
FREE_DAILY_LIMIT=20

# ─── 管理员令牌（用于 /admin/* 接口鉴权）────────────────────
ADMIN_TOKEN=<随机生成的管理员令牌，至少 32 字符>

# ─── 单次请求最大扣费（安全熔断，单位：分）─────────────────
# 超过此值会返回 HTTP 402，防止单次调用把余额耗尽
MAX_SINGLE_REQUEST_FEN=1000

# ─── 服务配置 ────────────────────────────────────────────────
PORT=3002
NODE_ENV=production
LOG_LEVEL=info
TZ=Asia/Shanghai

# ─── Node.js 内存限制 ────────────────────────────────────────
# CXI4 上 Webhook 分配 256MB
NODE_OPTIONS=--max-old-space-size=256
