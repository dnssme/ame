# =============================================================
# Anima 灵枢 · Webhook 计费服务环境变量
# 部署节点：VPS E (172.16.1.6) — 香港 Azure
#
# 使用方法：
#   cp .env.example .env
#   vim .env  # 替换所有 <占位符> 为真实值
#   chmod 600 .env
# =============================================================

# ─── PostgreSQL 数据库（Azure 托管）─────────────────────────
PG_HOST=anima-db.postgres.database.azure.com
PG_PORT=5432
PG_USER=animaapp
PG_PASSWORD=<Azure PostgreSQL 密码>
PG_DATABASE=librechat

# ─── Redis（VPS-E 本机，用于免费用户每日限额计数）────────────
# ⚠️ 必须包含密码，否则连接会静默失败导致免费限额失效
REDIS_URL=redis://:<Redis密码>@127.0.0.1:6379
# Redis 容器 requirepass 参数读取此变量
REDIS_PASSWORD=<Redis密码，与 REDIS_URL 中一致>

# ─── 免费用户每日调用次数限制 ─────────────────────────────────
# 免费模型（is_free=true）每用户每日最多调用次数
# 付费模型不受此限制
FREE_DAILY_LIMIT=20

# ─── Redis 免费限额 fail-closed 模式（可选）──────────────────
# 默认 true（fail-closed）：Redis 不可用时拒绝免费请求（HTTP 503），
# 防止 Redis 宕机期间无限调用免费模型耗尽上游 API 配额。
# 设为 false 可切换为 fail-open（优先保可用性，Redis 宕机时放行免费请求）。
# FREE_LIMIT_REDIS_REQUIRED=true

# ─── 管理员令牌（用于 /admin/* 接口鉴权）────────────────────
ADMIN_TOKEN=<随机生成的管理员令牌，至少 64 字符，建议 openssl rand -hex 32>

# ─── 内部服务鉴权令牌（用于 /billing/record 写入接口）───────
# OpenClaw 等内部服务调用 /billing/record 时携带此 Token
# ⚠️ 未配置则拒绝所有写入请求（fail-closed），务必设置并与 openclaw SERVICE_TOKEN 保持一致
SERVICE_TOKEN=<随机生成的服务间鉴权令牌，至少 64 字符，建议 openssl rand -hex 32>

# ─── 充值卡激活鉴权令牌（用于 /activate 接口）────────────────
# 内部服务调用 /activate 充值卡激活时携带此 Token（X-Activation-Token 头）
# ⚠️ 未配置则 /activate 端点返回 503（fail-closed），如需充值卡功能务必设置
# ⚠️ 必须与 ADMIN_TOKEN、SERVICE_TOKEN 不同（PCI-DSS 2.1 唯一凭据要求）
ACTIVATION_TOKEN=<随机生成的激活鉴权令牌，至少 64 字符，建议 openssl rand -hex 32>

# ─── 单次请求最大扣费（安全熔断，单位：分）─────────────────
# 超过此值会返回 HTTP 402，防止单次调用把余额耗尽
MAX_SINGLE_REQUEST_FEN=1000

# ─── USD → CNY 汇率（用于国际模型定价换算）─────────────────
# Anthropic/OpenAI/Google 等 USD 定价模型按此汇率换算为人民币分
# 不设置时代码默认使用 7.2；请定期更新为当前中间价
# 参考：https://www.boc.cn/sourcedb/whpj/
USD_TO_CNY_RATE=7.2

# ─── 服务配置 ────────────────────────────────────────────────
PORT=3002
# Docker 容器内必须绑定 0.0.0.0；裸机部署可改为内网 IP（如 172.16.1.6）
HOST=0.0.0.0
NODE_ENV=production
LOG_LEVEL=info
TZ=Asia/Shanghai

# ─── Nginx 反向代理 IP（用于 trust proxy，获取客户端真实 IP）─
# 若 Nginx 部署 IP 变更，需同步修改
TRUST_PROXY=172.16.1.1

# ─── Node.js 内存限制 ────────────────────────────────────────
# VPS-E 上 Webhook 分配 256MB
NODE_OPTIONS=--max-old-space-size=256

# ─── PostgreSQL 连接池大小（可选）──────────────────────────────
# 有效范围：1-100，超出则回退至默认值 10
# PG_POOL_MAX=10

# ─── 优雅关闭超时（可选，单位：毫秒）──────────────────────────
# 收到 SIGTERM 后等待请求完成的最大时间，范围 5000-60000，默认 10000
# GRACEFUL_SHUTDOWN_TIMEOUT=10000

# ─── 模块注册表路径（管理控制台读取模块状态，可选）─────────────
# 默认路径: ../modules/modules.yml（相对于 server.js）
# Docker 部署时可挂载宿主机路径或设为绝对路径
# MODULES_YML_PATH=/app/modules.yml
