# =============================================================
# Anima 灵枢 · 用户网盘模块环境变量
# =============================================================

# ─── Nextcloud 配置 ─────────────────────────────────────────
# 如已部署 calendar 模块（含 Nextcloud），此配置与之共用
NEXTCLOUD_URL=http://172.16.1.4:8090
NEXTCLOUD_USERNAME=admin
NEXTCLOUD_PASSWORD=<Nextcloud admin 密码>

# ─── 数据库 ────────────────────────────────────────────────
PG_PASSWORD=<animaapp 数据库密码>

# ─── 存储限额（每用户，单位 MB）──────────────────────────────
USER_QUOTA_MB=5120

# ─── 日志 ────────────────────────────────────────────────────
LOG_LEVEL=info
TZ=Asia/Shanghai
