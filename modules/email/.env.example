# =============================================================
# Anima 灵枢 · 邮件处理模块环境变量
# =============================================================

# ─── IMAP 收件配置 ──────────────────────────────────────────
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=<你的邮箱>
IMAP_PASSWORD=<邮箱 IMAP 密码/授权码>
IMAP_TLS=true

# ─── SMTP 发件配置 ──────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=<你的邮箱>
SMTP_PASSWORD=<邮箱 SMTP 密码/授权码>
SMTP_SECURE=true
SMTP_FROM=Anima AI <your-email@gmail.com>

# ─── 邮件检查间隔（秒）──────────────────────────────────────
CHECK_INTERVAL=300

# ─── AI 后端 ────────────────────────────────────────────────
AGENT_API_URL=http://172.16.1.2:3000
AGENT_DEFAULT_MODEL=glm-4-flash  # ★ 默认免费模型（智谱官方免费，0 成本）★

# ─── 通知（预留扩展位）──────────────────────────────────────
# Telegram 通知功能尚未实现，保留注释供未来扩展
# NOTIFY_TELEGRAM_ENABLED=false
# NOTIFY_TELEGRAM_BOT_TOKEN=<Bot Token>
# NOTIFY_TELEGRAM_CHAT_ID=<Chat ID>

# ─── 日志 ────────────────────────────────────────────────────
LOG_LEVEL=info
TZ=Asia/Shanghai
