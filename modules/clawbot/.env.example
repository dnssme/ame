# =============================================================
# Anima 灵枢 · 微信 ClawBot 插件灵枢接入通道 v2.7 环境变量
#
# 接入方式：
#   ✅ 微信公众号官方接入（扫码关注 / App 互通）— 默认启用
#   ✅ 微信 OAuth2.0 网页授权（简化用户接入流程）— 可选
#   ✅ 支持明文模式和安全模式（AES-256-CBC 加解密）
#   ✅ 模板消息 / 小程序卡片 / 客服转接 / 快捷回复 — v2.1
#   ✅ 官方 ClawBot 插件清单/状态端点 — v2.3
#   ✅ 会话静态加密 AES-256-GCM（PCI-DSS 3.4）— v2.3
#   ✅ 插件验证/合规报告/健康仪表板/用户同意/偏好设置 — v2.4
#   ✅ CIS v8 安全头增强（HSTS/CSP/Permissions-Policy）— v2.4
#   ✅ 多租户隔离/API密钥管理/插件心跳/能力协商/合规历史 — v2.5
#   ✅ 自助激活/企业运维增强/持续合规监控 — v2.5
#   ✅ 灵枢通道网关/接入向导/Webhook事件中继/会话联邦/实时合规 — v2.6
#   ✅ Web 管理后台（唯一管理入口 /clawbot/admin）— v2.7
#   ⬜ 企业微信（WeCom）— 接口已添加，默认不启用
# =============================================================

# ─── ClawBot 配置（微信公众号官方接入）────────────────────────
# 微信 ClawBot 插件分配的 Token（用于签名验证）
CLAWBOT_TOKEN=<你的 ClawBot Token>

# 微信 ClawBot 插件分配的 AppID
CLAWBOT_APP_ID=<你的 ClawBot AppID>

# 微信 ClawBot 插件分配的 AppSecret
CLAWBOT_APP_SECRET=<你的 ClawBot AppSecret>

# 微信 ClawBot 插件的 EncodingAESKey（消息加解密密钥）
# 配置此项后自动启用安全模式（AES-256-CBC 消息加解密）
# 不配置则使用明文模式
CLAWBOT_ENCODING_AES_KEY=<你的 EncodingAESKey>

# ─── AI 后端 ────────────────────────────────────────────────
AGENT_API_URL=http://172.16.1.2:3000
AGENT_DEFAULT_MODEL=glm-4-flash

# ─── 超时配置（毫秒）────────────────────────────────────────
# Agent API 调用超时（undici bodyTimeout/headersTimeout）
# 注意：AbortController 兜底超时 = AGENT_REQUEST_TIMEOUT_MS + 30000
AGENT_REQUEST_TIMEOUT_MS=60000

# Billing API 调用超时（/balance 查询等）
BILLING_REQUEST_TIMEOUT_MS=10000

# ─── 计费 ────────────────────────────────────────────────────
BILLING_WEBHOOK_URL=http://172.16.1.6:3002

# ─── PostgreSQL（审计日志 + 用户记录持久化，PCI-DSS 10.2）──
# 连接到 Azure PostgreSQL（与 Webhook 服务共用数据库）
# 格式：postgresql://user:password@host:port/dbname?sslmode=require
DATABASE_URL=postgresql://animaapp:<your_pg_password>@<your_pg_host>:5432/librechat?sslmode=require

# ─── Redis（会话上下文 + 用户认证 + 邮箱绑定持久化）────────
REDIS_URL=redis://:<your_redis_password>@172.16.1.6:6379
SESSION_TTL=3600

# ─── 语音处理（可选，启用后支持语音消息完整处理链路）────────
# 设为 true 启用 Whisper STT + TTS 语音处理
# 设为 false 时语音消息仍可通过微信自带语音识别处理文字
VOICE_ENABLED=false
WHISPER_URL=http://172.16.1.5:8080/transcribe
TTS_URL=http://172.16.1.5:8082/api/tts

# ─── 服务端口 ────────────────────────────────────────────────
PORT=3004

# ─── 会话管理 ────────────────────────────────────────────────
# 最大同时缓存的会话数量（超过时淘汰最久未活跃的会话）
MAX_SESSIONS=500

# ─── Per-user 速率限制（PCI-DSS / CIS DoS 缓解）──────────
# 单用户每分钟最大请求数（范围 1-300，默认 30）
# 超出限制后消息会被拒绝，返回"操作过于频繁"提示
USER_RATE_LIMIT=30

# ─── 长耗时任务关键词 ────────────────────────────────────────
# 包含以下关键词的消息会切换到异步模式（先回复"处理中"再返回结果）
# 支持自定义，逗号分隔
LONG_RUNNING_KEYWORDS=搜索,搜一下,查一下,帮我搜,search,分析文件,分析一下,看看这个文件,analyze,邮件,查邮件,email,文件列表,list files

# ─── 登录安全（PCI-DSS 8.1.6 登录锁定）─────────────────────
# 绑定邮箱连续失败最大次数（达到后锁定，范围 3-20，默认 6）
BIND_LOCKOUT_THRESHOLD=6

# 锁定持续时间（分钟，范围 5-1440，默认 30）
BIND_LOCKOUT_DURATION_MIN=30

# ─── 空闲会话超时（PCI-DSS 8.1.8）─────────────────────────
# 会话空闲超时（分钟，范围 1-120，默认 15）
# 超过此时间未操作需重新认证
IDLE_SESSION_TIMEOUT_MIN=15

# ─── 审计日志保留（PCI-DSS 10.7）───────────────────────────
# 审计日志保留天数（范围 90-3650，默认 365）
AUDIT_RETENTION_DAYS=365

# ─── 日志 ────────────────────────────────────────────────────
LOG_LEVEL=info
TZ=Asia/Shanghai

# ─── 企业运维 ────────────────────────────────────────────────
# 管理端点认证令牌（/clawbot/qrcode 和 /stats 端点需要）
# 最少 32 字符，与 Webhook 服务的 SERVICE_TOKEN 保持一致
# SERVICE_TOKEN=<64+ char random token>

# 优雅关闭超时（秒），范围 5-60，默认 10
# GRACEFUL_SHUTDOWN_TIMEOUT=10

# 生产环境标识（建议设置为 production）
# NODE_ENV=production

# ─── 管理端点 IP 白名单（CIS 网络访问限制）────────────────
# 逗号分隔的 IP 列表，配置后仅允许列出 IP 访问管理端点
# 不配置或留空时不限制（向后兼容）
# ADMIN_IP_ALLOWLIST=127.0.0.1,172.16.1.1

# =============================================================
# 微信 OAuth2.0 网页授权（可选，简化用户接入流程）
# 配置后用户可通过网页链接一键授权绑定，无需手动 /bind 邮箱
# 需在微信公众号后台配置"网页授权域名"
# =============================================================

# OAuth 回调 URL（完整 URL，必须与公众号后台配置的域名一致）
# 例：https://your-domain.com/clawbot/oauth/callback
# OAUTH_REDIRECT_URI=https://<你的域名>/clawbot/oauth/callback

# OAuth scope（默认 snsapi_userinfo 获取昵称头像，snsapi_base 静默授权仅获取 OpenID）
# OAUTH_SCOPE=snsapi_userinfo

# OAuth state 有效期（秒，范围 60-600，默认 300）
# OAUTH_STATE_TTL=300

# =============================================================
# v2.7 新增功能配置
# =============================================================

# ─── Web 管理后台（ENT-2.7-1, PCI-DSS 8.2.8）──────────────────
# GET    /clawbot/admin                      — Web 管理后台 SPA 页面
# POST   /clawbot/admin/api/login            — 管理员登录（需 SERVICE_TOKEN + IP 白名单）
# POST   /clawbot/admin/api/logout           — 管理员登出

# 管理会话空闲超时（秒，范围 300-3600，默认 900 即 15 分钟）
# 符合 PCI-DSS 8.2.8 ≤15 分钟空闲超时要求
# ADMIN_SESSION_TTL=900

# 管理会话硬过期时间（秒，范围 1800-86400，默认 3600 即 1 小时）
# 无论是否活跃，超过此时间强制重新登录
# ADMIN_SESSION_MAX_AGE=3600

# =============================================================
# v2.6 新增功能配置
# =============================================================

# ─── 灵枢通道网关（ENT-2.6-1）────────────────────────────────
# POST   /clawbot/gateway/channels           — 注册通道（需 SERVICE_TOKEN 认证）
# GET    /clawbot/gateway/channels           — 列出通道（需 SERVICE_TOKEN 认证）
# GET    /clawbot/gateway/channels/:id       — 通道详情（需 SERVICE_TOKEN 认证）
# DELETE /clawbot/gateway/channels/:id       — 删除通道（需 SERVICE_TOKEN 认证）
# POST   /clawbot/gateway/channels/:id/heartbeat — 通道心跳
# GET    /clawbot/gateway/features           — 能力矩阵（需 SERVICE_TOKEN 认证）

# ─── Webhook 事件中继（ENT-2.6-3, PCI-DSS 4.2.1）──────────────
# POST   /clawbot/relay/subscriptions        — 创建订阅（需 SERVICE_TOKEN 认证）
# GET    /clawbot/relay/subscriptions        — 列出订阅（需 SERVICE_TOKEN 认证）
# DELETE /clawbot/relay/subscriptions/:subId — 删除订阅（需 SERVICE_TOKEN 认证）
# POST   /clawbot/relay/test                — 测试投递（需 SERVICE_TOKEN 认证）

# Webhook 投递超时（毫秒，范围 3000-30000，默认 10000）
# RELAY_DELIVERY_TIMEOUT_MS=10000

# Webhook 投递最大重试次数（范围 0-5，默认 3）
# RELAY_MAX_RETRIES=3

# ─── 跨通道会话联邦（ENT-2.6-4）──────────────────────────────
# POST   /clawbot/federation/links           — 创建会话链接（需 SERVICE_TOKEN 认证）
# GET    /clawbot/federation/links           — 查询会话链接（需 SERVICE_TOKEN 认证）
# DELETE /clawbot/federation/links/:linkId   — 删除会话链接（需 SERVICE_TOKEN 认证）

# ─── 实时合规监控（ENT-2.6-5）──────────────────────────────────
# GET    /clawbot/compliance/realtime        — 实时合规状态（需 SERVICE_TOKEN 认证）
# 含合规漂移检测、趋势分析、PCI-DSS/CIS 全项实时检查

# ─── 接入向导 ──────────────────────────────────────────────────
# 用户发送 /setup 启动分步引导向导
# 自动检测用户状态并提供上下文指引
# 引导路径：绑定 → 同意 → 激活 → 设置

# =============================================================
# v2.5 新增功能配置
# =============================================================

# ─── 插件心跳间隔（秒，范围 30-300，默认 60）────────────────
# 微信平台定期检查插件活跃度的心跳间隔
# PLUGIN_HEARTBEAT_INTERVAL=60

# ─── 合规自动扫描间隔（毫秒，范围 1h-7d，默认 24h）──────────
# PCI-DSS / CIS 合规自检定时扫描间隔
# COMPLIANCE_SCAN_INTERVAL_MS=86400000

# ─── 多租户管理 ────────────────────────────────────────────────
# POST /clawbot/tenants           — 创建租户（需 SERVICE_TOKEN 认证）
# GET  /clawbot/tenants           — 列出租户（需 SERVICE_TOKEN 认证）
# GET  /clawbot/tenants/:id       — 租户详情（需 SERVICE_TOKEN 认证）
# PATCH /clawbot/tenants/:id/status — 更新状态（需 SERVICE_TOKEN 认证）

# ─── API 密钥管理（PCI-DSS 8.2.3）─────────────────────────────
# POST   /clawbot/tenants/:id/keys       — 创建密钥
# GET    /clawbot/tenants/:id/keys       — 列出密钥
# DELETE /clawbot/tenants/:id/keys/:keyId — 吊销密钥
# 密钥以 SHA-256 散列存储（PCI-DSS 3.4）

# ─── 插件协议端点 ──────────────────────────────────────────────
# POST /clawbot/plugin/heartbeat  — 插件心跳（微信平台定期调用）
# POST /clawbot/plugin/negotiate  — 能力协商（微信平台验证插件能力）

# ─── 合规审计历史 ──────────────────────────────────────────────
# GET  /clawbot/compliance/history — 合规快照历史（需 SERVICE_TOKEN 认证）

# ─── 自助激活 ──────────────────────────────────────────────────
# 用户发送 /activate 一键激活 ClawBot 插件
# 激活记录持久化到 PostgreSQL clawbot_plugin_log 表

# =============================================================
# v2.4 新增功能配置
# =============================================================

# ─── 插件验证端点 ─────────────────────────────────────────────
# POST /clawbot/plugin/verify — 插件验证挑战-响应（官方商店认证）
# GET  /clawbot/plugin/health — 插件健康仪表板（需 SERVICE_TOKEN 认证）
# GET  /clawbot/compliance/report — 合规性报告（需 SERVICE_TOKEN 认证）

# ─── 用户同意管理（PCI-DSS v4.0 / GDPR）──────────────────────
# 用户发送 /consent 查看数据处理协议
# 用户发送 /consent agree 同意协议
# 同意记录持久化到 PostgreSQL clawbot_user_consent 表

# ─── 用户偏好设置 ─────────────────────────────────────────────
# 用户发送 /settings 查看和管理个人偏好
# 支持语言切换、通知开关、自动语音回复
# 设置持久化到 PostgreSQL clawbot_user_settings 表

# =============================================================
# v2.3 新增功能配置
# =============================================================

# ─── 会话静态加密（PCI-DSS 3.4 数据保护）────────────────────
# Redis 中存储的会话数据使用 AES-256-GCM 加密
# 密钥格式：64 个十六进制字符（32 字节）
# 生成命令：openssl rand -hex 32
# 不配置时会话以明文存储（向后兼容）
# SESSION_ENCRYPT_KEY=<64位十六进制密钥>

# ─── 插件端点说明 ─────────────────────────────────────────────
# GET /clawbot/plugin/manifest — 插件清单（无需认证，供微信平台验证）
# GET /clawbot/plugin/status  — 插件状态（需 SERVICE_TOKEN 认证）

# =============================================================
# v2.1 新增功能配置
# =============================================================

# ─── 敏感操作二次确认（PCI-DSS v4.0）───────────────────────────
# /unbind 操作需要用户在指定秒数内发送 /unbind confirm 确认
# 默认 120 秒，范围 30-600
# UNBIND_CONFIRM_TTL=120

# ─── 模板消息（官方服务通知）──────────────────────────────────
# 模板消息通过管理端点 POST /clawbot/template/send 发送
# 需要先在微信公众号后台申请模板 ID
# 发送记录持久化到 PostgreSQL clawbot_template_log 表

# ─── 客服转接 ────────────────────────────────────────────────
# 用户发送 /transfer 命令或管理端调用 POST /clawbot/kf/transfer
# 需要在微信公众号后台配置多客服功能

# ─── 快捷回复规则 ────────────────────────────────────────────
# 通过管理端点 POST /clawbot/quickreply 创建
# 支持精确匹配（exact）和模糊匹配（fuzzy）
# 规则存储在 Redis，优先级高于 AI 对话

# ─── 小程序卡片消息 ──────────────────────────────────────────
# 通过管理端点 POST /clawbot/miniprogram/send 发送
# 需要关联的小程序 AppID

# =============================================================
# 企业微信（WeCom）接口配置
# 注意：接口已添加但默认不启用，如需使用请设置 WECOM_ENABLED=true
# 企业微信与微信公众号完全隔离，使用独立的 Redis 键空间
# =============================================================

# 是否启用企业微信接口（默认 false，不使用）
WECOM_ENABLED=false

# 企业微信 CorpID（企业 ID）
# WECOM_CORPID=<你的企业微信 CorpID>

# 企业微信应用 Secret
# WECOM_SECRET=<你的企业微信应用 Secret>

# 企业微信回调 Token（用于签名验证）
# WECOM_TOKEN=<你的企业微信回调 Token>

# 企业微信 EncodingAESKey（消息加解密密钥）
# WECOM_ENCODING_AES_KEY=<你的企业微信 EncodingAESKey>

# 企业微信应用 AgentID
# WECOM_AGENT_ID=<你的企业微信应用 AgentID>
